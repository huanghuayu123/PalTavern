    "@pixi/react": "8.0.0-beta.25",
    "@vueuse/components": "^14.2.1",
    "@vueuse/core": "^13.9.0",
    "@vueuse/integrations": "^13.9.0",
    "@vueuse/shared": "^13.9.0",
    "async-wait-until": "^2.0.31",
    "axios": "1.14.0",
    "compare-versions": "^6.1.1",
    "dedent": "^1.7.2",
