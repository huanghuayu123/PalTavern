    "socket.io": "^4.8.3",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.2",
    "terser-webpack-plugin": "^5.4.0",
    "ts-loader": "^9.5.7",
    "ts-node": "^10.9.2",
    "tsconfig-paths-webpack-plugin": "^4.2.0",
    "tslib": "^2.8.1",
    "type-fest": "^4.41.0",
    "typescript": "6.0.0-dev.20250807",
    "typescript-eslint": "^8.58.1",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^29.2.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-loader": "^17.4.2",
