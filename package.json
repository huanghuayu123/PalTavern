    "eslint-webpack-plugin": "^5.0.3",
    "globals": "^16.5.0",
    "html-inline-css-loader": "^0.2.1",
    "html-inline-css-webpack-plugin": "^1.11.2",
    "html-inline-script-webpack-plugin": "^3.2.1",
    "html-loader": "^5.1.0",
