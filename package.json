{
  "name": "pal-tavern",
  "version": "1.1.04",
  "private": true,
  "main": "desktop/main.cjs",
  "scripts": {
    "local:build": "pnpm build:dev",
    "local:serve": "node scripts/serve-independent-chat.mjs",
    "serve": "node scripts/serve-independent-chat.mjs",
    "electron:dev": "pnpm local:build && electron desktop/main.cjs",
    "electron:pack": "pnpm build && electron-builder --dir",
    "electron:dist": "pnpm build && electron-builder",
    "android:check": "node scripts/check-android-background-readiness.mjs && pnpm test:android-launch && pnpm test:android-webview",
    "test:android-launch": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-android-launch-theme.ts",
    "test:android-webview": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-android-webview-compat.ts",
    "desktop:check": "node scripts/check-desktop-readiness.mjs",
    "test:moments": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-independent-moments.ts",
    "test:independent-core": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-independent-core.ts",
    "test:groups": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-independent-groups.ts",
    "test:tavern-export": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-tavern-export.ts",
    "test:authoring": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-character-authoring.ts",
    "test:model-list": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-model-list.ts",
    "test:prompt-presets": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-prompt-presets.ts",
    "test:prompt-suite": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-prompt-suite.ts",
    "test:model-list-proxy": "node scripts/test-model-list-proxy.mjs",
    "test:png-card-v3": "node scripts/test-png-card-v3.mjs",
    "test:events": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-independent-events.ts",
    "test:character-interactions": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-character-interaction-loop.ts",
    "test:character-direct-chat": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-character-direct-chat.ts",
    "test:memory-summaries": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-memory-summaries.ts",
    "test:status-briefs": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-status-briefs.ts",
    "test:auto-runtime": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-auto-message-runtime.ts",
    "test:auto-failure": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-auto-message-failure.ts",
    "test:backup": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-independent-backup.ts",
    "test:app-dialogs": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-app-dialogs.ts",
    "test:ux-safety": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-ux-safety.ts",
    "test:welcome-cover": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/test-welcome-cover.ts",
    "test:independent": "pnpm test:independent-core && pnpm test:groups && pnpm test:auto-runtime && pnpm test:auto-failure && pnpm test:moments && pnpm test:events && pnpm test:character-interactions && pnpm test:character-direct-chat && pnpm test:memory-summaries && pnpm test:status-briefs && pnpm test:backup && pnpm test:app-dialogs && pnpm test:ux-safety && pnpm test:welcome-cover && pnpm test:tavern-export && pnpm test:authoring && pnpm test:model-list && pnpm test:prompt-presets && pnpm test:prompt-suite && pnpm test:model-list-proxy && pnpm test:png-card-v3",
    "prompt:eval": "ts-node --transpile-only --project scripts/tsconfig.independent-tests.json scripts/run-prompt-live-eval.ts",
    "typecheck:independent": "node node_modules/typescript/bin/tsc --project scripts/tsconfig.independent-source.json",
    "icons:android": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/generate-android-icons.ps1",
    "android:sync": "pnpm icons:android && pnpm build && node node_modules/@capacitor/cli/bin/capacitor sync android",
    "android:open": "node node_modules/@capacitor/cli/bin/capacitor open android",
    "android:build": "pnpm icons:android && pnpm build && node node_modules/@capacitor/cli/bin/capacitor sync android && cd android && gradlew.bat assembleDebug",
    "build:dev": "webpack --config webpack.tavern-social.config.mjs --mode development",
    "build": "webpack --config webpack.tavern-social.config.mjs --mode production",
    "watch": "webpack --config webpack.tavern-social.config.mjs --mode development --watch --progress",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,scss,html,vue}\" --no-error-on-unmatched-pattern",
    "lint": "eslint",
    "lint:fix": "eslint --fix"
  },
  "browserslist": [
    "defaults and partially supports es6-module"
  ],
